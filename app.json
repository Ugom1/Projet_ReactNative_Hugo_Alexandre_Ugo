{
  "expo": {
    "name": "DTM",
    "slug": "dtm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dreamteammaker",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.projetreactnative.dtm"
    },
    "android": {
      "package": "com.projetreactnative.dtm",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0A"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Autoriser l'accès aux photos pour ta photo de profil."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "5d10d9f0-fc28-44c6-828c-92a2b41dc3e1"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/5d10d9f0-fc28-44c6-828c-92a2b41dc3e1"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "projetreactnative",
    "experiments": {
      "typedRoutes": true
    }
  }
}
